    "npcs": [
      {
        "name": "Sister Vesper",
        "npc_type": "priest",
        "col": 18,
        "row": 24,
        "dialogue": [
          "Welcome to the Shrine of Noxara, child.",
          "The light of Noxara heals all wounds.",
          "We offer healing and resurrection for those in need.",
          "May Noxara's radiance guide your path."
        ],
        "shop_type": "general",
        "god_name": "Noxara",
        "wander_range": 4
      },
      {
        "name": "Lira",
        "npc_type": "shopkeep",
        "col": 18,
        "row": 14,
        "dialogue": [
          "Ah",
          "customers! Welcome to Lira's Trading Post.",
          "You won't find better quality anywhere else.",
          "Every item here has been tested in the field.",
          "Gold well spent is gold well earned!"
        ],
        "shop_type": "general",
        "god_name": "The Divine",
        "wander_range": 4
      },
      {
        "name": "Doric",
        "npc_type": "innkeeper",
        "col": 28,
        "row": 14,
        "dialogue": [
          "Come in, come in! The Hearthstone is the warmest spot in town.",
          "Hot stew and a soft bed -- what more could you want?",
          "Travelers bring all sorts of stories through here.",
          "Stay as long as you like!"
        ],
        "shop_type": "general",
        "god_name": "The Divine",
        "wander_range": 4
      },
      {
        "name": "Elder Rowan",
        "npc_type": "elder",
        "col": 23,
        "row": 19,
        "dialogue": [
          "You carry the look of adventurers. Good -- we need heroes.",
          "Our scouts report growing dangers in every direction.",
          "The ancient wards are failing. Something must be done.",
          "I pray you have the courage to see this through."
        ],
        "shop_type": "general",
        "god_name": "The Divine",
        "wander_range": 4
      },
      {
        "name": "Calla",
        "npc_type": "villager",
        "col": 19,
        "row": 25,
        "dialogue": [
          "Have you heard about the old ruins?",
          "They say treasure lies within."
        ],
        "shop_type": "general",
        "god_name": "The Divine",
        "wander_range": 4
      },
      {
        "name": "Finn",
        "npc_type": "villager",
        "col": 27,
