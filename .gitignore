# ── Build artifacts (PyInstaller / packaging) ─────────────────────
# These are generated by running the build / packaging scripts and
# are uploaded to GitHub Releases separately, so they should never
# be tracked in source control.
dist/
build/

# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/

# ── OS / editor cruft ─────────────────────────────────────────────
.DS_Store
docs/blog/.DS_Store

# ── Tooling state ─────────────────────────────────────────────────
.claude/
